# Copy to .env.test and fill in your local test database URL.
# Create the database first: createdb bandwagon_test

TEST_DATABASE_URL=postgresql://localhost:5432/bandwagon_test
JWT_SECRET=e2e-test-secret
PORT=3001
FRONTEND_URL=http://localhost:5173

# Override the day-of-week used by the lineup lock check (only applies in NODE_ENV=test).
# Set to "Monday" to allow lineup swaps. Set to "Tuesday" to test the lock.
# Leave blank to use the real current day.
TEST_OVERRIDE_DAY=Monday
