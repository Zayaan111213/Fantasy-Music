generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  username     String?  @unique
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teams              Team[]
  commissionedLeagues League[] @relation("Commissioner")
  notifications      Notification[]
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  message   String
  seenAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model League {
  id             String    @id @default(cuid())
  name           String
  commissionerId String
  commissioner   User      @relation("Commissioner", fields: [commissionerId], references: [id])
  teamCount      Int       @default(8)
  isPrivate      Boolean   @default(true)
  draftTime      DateTime?
  status         String    @default("pending")
  inviteCode     String    @unique
  currentWeek    Int       @default(1)
  seasonYear     Int       @default(2026)
  scoringConfig  Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  teams      Team[]
  matchups   Matchup[]
  draftPicks DraftPick[]
  draftState DraftState?
}

model Team {
  id             String @id @default(cuid())
  leagueId       String
  userId         String
  name           String
  logoUrl        String?
  waiverPriority Int    @default(0)
  wins           Int    @default(0)
  losses         Int    @default(0)
  pointsFor      Float  @default(0)
  draftPosition  Int?
  createdAt      DateTime @default(now())

  league       League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id])
  rosterSpots  RosterSpot[]
  homeMatchups Matchup[]   @relation("HomeTeam")
  awayMatchups Matchup[]   @relation("AwayTeam")
  draftPicks   DraftPick[]

  @@unique([leagueId, userId])
}

model Artist {
  id             String   @id @default(cuid())
  name           String
  primaryGenre   String
  imageUrl       String?
  spotifyId      String?
  appleMusicId   String?
  appleArtistId   BigInt?  @unique
  createdAt       DateTime @default(now())
  genreEnrichedAt DateTime?

  weeklyScores      WeeklyScore[]
  rosterSpots       RosterSpot[]
  draftPicks        DraftPick[]
  chartEntries      ChartEntry[]
  albumChartEntries AlbumChartEntry[]
}

model ChartEntry {
  id          String   @id @default(cuid())
  weekDate    DateTime @db.Date
  chart       String
  rank        Int
  songTitle   String
  appleSongId BigInt?
  artistId    String?
  artist      Artist?  @relation(fields: [artistId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@unique([weekDate, chart, rank])
  @@index([weekDate])
  @@index([artistId])
}

model AlbumChartEntry {
  id           String   @id @default(cuid())
  weekDate     DateTime @db.Date
  chart        String
  rank         Int
  albumTitle   String
  appleAlbumId BigInt?
  artistId     String?
  artist       Artist?  @relation(fields: [artistId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@unique([weekDate, chart, rank])
  @@index([weekDate])
  @@index([artistId])
}

model RosterSpot {
  id       String  @id @default(cuid())
  teamId   String
  artistId String?
  slot     String

  team   Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  artist Artist? @relation(fields: [artistId], references: [id])

  @@unique([teamId, slot])
}

model WeeklyScore {
  id                  String   @id @default(cuid())
  artistId            String
  week                Int
  seasonYear          Int
  streamingPoints     Float    @default(0)
  chartPositionPoints Float    @default(0)
  chartMovementPoints Float    @default(0)
  longevityPoints     Float    @default(0)
  totalPoints         Float    @default(0)
  weeklyStreams        BigInt?
  bestChartPosition   Int?
  chartMovement       Int?
  isFinalized         Boolean  @default(false)
  dataMissing         String?

  // Per-signal breakdown, captured at scoring time so past weeks can show
  // why an artist scored what they did (not just the combined totals above).
  songRank            Int?
  songTitle           String?
  songPositionPoints  Float    @default(0)
  songMovement        Int?
  songMovementPoints  Float    @default(0)
  songIsDebut         Boolean  @default(false)
  albumRank           Int?
  albumTitle          String?
  albumPositionPoints Float    @default(0)
  albumMovement       Int?
  albumMovementPoints Float    @default(0)
  albumIsDebut        Boolean  @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  artist Artist @relation(fields: [artistId], references: [id])

  @@unique([artistId, week, seasonYear])
}

model Matchup {
  id          String  @id @default(cuid())
  leagueId    String
  week        Int
  homeTeamId  String
  awayTeamId  String
  homeScore   Float   @default(0)
  awayScore   Float   @default(0)
  winnerId    String?
  isFinalized Boolean @default(false)
  matchupType String  @default("regular") // regular | semifinal | championship | third_place | consolation_semifinal | fifth_place | seventh_place
  homeSeed    Int?
  awaySeed    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  homeTeam Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  @@unique([leagueId, week, homeTeamId])
}

model DraftPick {
  id         String   @id @default(cuid())
  leagueId   String
  teamId     String
  artistId   String
  round      Int
  pickNumber Int
  slot       String
  isAutoDraft Boolean @default(false)
  pickedAt   DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id])
  artist Artist @relation(fields: [artistId], references: [id])

  @@unique([leagueId, pickNumber])
}

model DraftState {
  id           String   @id @default(cuid())
  leagueId     String   @unique
  currentPick  Int      @default(0)
  pickOrder    String[]
  timerEndsAt  DateTime?
  isComplete   Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
}

model GenreStreamingTier {
  id         String @id @default(cuid())
  genre      String
  minStreams  BigInt
  maxStreams  BigInt?
  points     Int
  sortOrder  Int

  @@index([genre, sortOrder])
}
